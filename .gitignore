# -----------------------------------------------------------------------------
# Python cache and build artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
build/
dist/
*.egg-info/
.codex/
AGENTS.md

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/*
!.venv/.gitkeep
venv/
env/

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
tmp*/
*.bak
*.swp
*.swo
Thumbs.db
.DS_Store

# -----------------------------------------------------------------------------
# Local analysis outputs and model artifacts
# -----------------------------------------------------------------------------
data/extracted/*
data/processed/*
data/outputs/*
models/
artifacts/
checkpoints/
local_docs/
*.pkl
*.joblib
*.onnx

# -----------------------------------------------------------------------------
# Notebook and editor local state
# -----------------------------------------------------------------------------
.idea/
.vscode/*.code-workspace

# -----------------------------------------------------------------------------
# Do not ignore committed raw zip files
# -----------------------------------------------------------------------------
!data/raw/
!data/raw/**
!data/raw/*.zip
!.gitkeep

# -----------------------------------------------------------------------------
# Canonical official reporting artifacts kept in git
# -----------------------------------------------------------------------------
!data/outputs/*official*
!data/outputs/component_textwave2b_calibration_manifest.json
